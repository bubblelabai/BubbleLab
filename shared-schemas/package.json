    "clean": "rm -rf dist",
    "test": "vitest run"
  },
  "dependencies": {
    "@mendable/firecrawl-js": "^3.2.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.0.15",
    "@typescript-eslint/eslint-plugin": "^8.37.0",
    "@typescript-eslint/parser": "^8.37.0",
    "eslint": "^9.31.0",
    "typescript": "^5.8.3",
    "vitest": "^2.1.8"
  },
  "peerDependencies": {
    "@hono/zod-openapi": "^1.0.2"
  }
}
